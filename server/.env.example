# Copy this file to .env and fill in your real values. Never commit .env itself.

# MongoDB connection string. If you install MongoDB locally, this default works.
# If you use MongoDB Atlas (cloud, free tier), paste the connection string Atlas gives you.
MONGODB_URI=mongodb://127.0.0.1:27017/mediavault

# Any long random string — used to sign login tokens. Just mash your keyboard.
JWT_SECRET=change-this-to-something-random

# From themoviedb.org -> Settings -> API -> "API Read Access Token"
TMDB_READ_ACCESS_TOKEN=paste-your-tmdb-token-here

PORT=5000
